<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
    "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <interface name="org.kde.KWin.SessionLock">

    <!-- Lock initiation: lock daemon calls this; KWin emits LockRequested -->
    <method name="lock"/>

    <!-- Grace period: lock client calls this on user input during lock -->
    <method name="notifyUserActivity"/>

    <!-- Inhibition: cookie-based, returns opaque uint cookie -->
    <method name="inhibit">
      <arg name="who"    type="s" direction="in"/>
      <arg name="reason" type="s" direction="in"/>
      <arg name="cookie" type="u" direction="out"/>
    </method>
    <method name="release">
      <arg name="cookie" type="u" direction="in"/>
    </method>

    <!-- State properties -->
    <property name="locked"        type="b" access="read"/>
    <property name="inhibited"     type="b" access="read"/>
    <property name="gracePeriodMs" type="i" access="read"/>

    <!-- Signals to lock client -->
    <signal name="lockRequested"/>
    <signal name="lockStateChanged">
      <arg name="locked" type="b"/>
    </signal>
    <signal name="unlockAuthorized"/>
    <signal name="prepareSuspend"/>
    <signal name="awoke"/>

  </interface>
</node>
